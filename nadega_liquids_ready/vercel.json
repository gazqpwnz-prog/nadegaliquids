{
  "version": 2,
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/liquids",
      "dest": "/liquids.html"
    },
    {
      "src": "/disposables",
      "dest": "/disposables.html"
    },
    {
      "src": "/pods",
      "dest": "/pods.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}